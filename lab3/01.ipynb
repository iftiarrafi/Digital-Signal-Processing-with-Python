   "source": [
    "import numpy as np\n",
    "x_2 = [0,0,1,2,3]\n",
    "h_2 = [4,5,6]\n",
    "h_2_prime = [6,5,4,0,0]\n",
    "y_2 = []\n",
    "\n",
    "while len(x_2) > 0 :\n",
    "  result = sum([x_2[i] * h_2_prime[i] for i in range(min(len(x_2), len(h_2_prime)))])\n",
    "  x_2.pop(0)\n",
    "  y_2.append(result)\n",
    "print( f\"h(n) : {y_2}\")"
   ]
  }
