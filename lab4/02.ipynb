    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "x = [1, 2, 3,4,5 ,9 ,4]\n",
    "y = [4, 5, 6,7,8,5,3]\n",
    "\n",
    "correlation = np.correlate(x, y, mode='full')\n",
    "\n",
    "plt.stem(correlation)\n",
    "plt.show()\n",
    "\n",
    "\n"
   ]
